# Application-specific Kconfig. Symbols defined here are layered on top of the
# normal Zephyr tree, which is pulled in by the trailing source line.

config APP_SPEAKER
	bool "Speaker tone shell command (LEDC PWM)"
	depends on PWM && SHELL
	help
	  Drive the speaker (XIAO header D3 / GPIO21) with a hardware LEDC PWM
	  channel: a 50% square wave at the requested frequency, generated by the
	  peripheral with no CPU work. Registers a "tone <centi-hz> <ms>" shell
	  command. The pin and channel are set in app.overlay.

config APP_MOTOR
	bool "A4988 stepper control with motor shell commands"
	depends on GPIO && PWM && SHELL
	help
	  Wire the A4988 stepper driver to the XIAO header and expose a "motor"
	  shell command group for bench debugging. STEP is D0 / GPIO0 / LEDC
	  channel 0 (the step pulse train), DIR is D1 / GPIO1, and EN is D2 /
	  GPIO2 (active-low). The pins are set in app.overlay. See DESIGN.md.

config APP_ANTENNA
	bool "Power the RF switch and select the onboard antenna"
	depends on GPIO
	help
	  The XIAO ESP32-C6 routes both the onboard antenna and the U.FL
	  connector through an RF switch (enable GPIO3, select GPIO14). A default
	  build leaves the switch unpowered, so the radio runs on a degraded
	  leakage path. This drives GPIO3 to power the switch and GPIO14 to select
	  the onboard antenna, reusing the board's rf_switch devicetree node. No
	  effect unless the radio is used. See docs/LOG.md [antenna].

config APP_WIFI
	bool "Auto-connect to a stored WiFi network at boot"
	depends on WIFI && NETWORKING && WIFI_CREDENTIALS_CONNECT_STORED
	help
	  At boot, request a connection to a network whose credentials are
	  stored in flash (NET_REQUEST_WIFI_CONNECT_STORED), retrying until the
	  WiFi interface is ready. Provision the credential once over the shell
	  ("wifi cred add ..."); it persists in the storage partition and the
	  board reconnects automatically on every reboot. The "wifi" shell
	  command group is still available for manual control. Lives in
	  app/src/wifi.c. See docs/LOG.md [wifi].

config APP_UPDATE
	bool "OTA firmware update shell command (HTTP/S -> inactive slot)"
	depends on SHELL && HTTP_CLIENT && NET_SOCKETS && DNS_RESOLVER && IMG_MANAGER && BOOTLOADER_MCUBOOT && SETTINGS
	help
	  Register an "update" shell command group that fetches a prebuilt,
	  signed image from a static endpoint (GitHub Pages by default) over
	  DNS + TLS and writes it into the slot the board is not running from,
	  then reboots so MCUboot (DirectXIP) boots the higher-version slot. The
	  base URL persists in the settings/NVS "update/url" key. TLS peer
	  verification is off for now (encrypt-only); see docs/OTA.md. Lives in
	  app/src/update.c.

config APP_UPDATE_URL
	string "Default OTA base URL"
	depends on APP_UPDATE
	default "https://tubbles.github.io/zephyr-pump"
	help
	  Base URL the board fetches from until overridden at the console with
	  "update url <url>". The board appends "/version" and
	  "/firmware-slot0.bin" or "/firmware-slot1.bin" (the variant for its
	  inactive slot).

source "Kconfig.zephyr"
