#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

/*
 * A4988 stepper control + LEDC speaker tone on the Seeed XIAO ESP32-C6 header
 * (see DESIGN.md). The control/audio lines use the SPI2 pins (D8-D10) plus D3,
 * which keeps the only ADC-capable header pins (D0-D2) free for battery sensing
 * and I2C0 (D4/D5) free for sensors. Re-pin by editing the numbers here; the C
 * in app/src reaches everything through the zephyr,user node.
 *
 *   STEP    = D10 / GPIO18 / LEDC ch0  -- the step pulse train
 *   DIR     = D9  / GPIO20             -- rotation direction (plain out)
 *   EN      = D8  / GPIO19             -- active-low driver enable
 *   speaker = D3  / GPIO21 / LEDC ch1  -- hardware square-wave tone
 */

/*
 * Free D8-D10 (GPIO19/20/18): the board enables spi2 on them by default, but the
 * pump uses I2C + ADC, not SPI, so release the pins for DIR/EN and STEP's PWM.
 */
&spi2 {
	status = "disabled";
};

/*
 * Two LEDC channels: ch0 -> STEP (GPIO18), ch1 -> speaker (GPIO21). They sit on
 * separate timers (0 and 1) so their frequencies are independent -- a timer's
 * frequency is shared by every channel bound to it. The espressif,esp32-ledc
 * binding is #pwm-cells = <3> (channel, period, flags).
 */
&pinctrl {
	ledc0_default: ledc0_default {
		group1 {
			pinmux = <LEDC_CH0_GPIO18>, <LEDC_CH1_GPIO21>;
			output-enable;
		};
	};
};

&ledc0 {
	pinctrl-0 = <&ledc0_default>;
	pinctrl-names = "default";
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel0@0 {
		reg = <0x0>;
		timer = <0>;
	};

	channel1@1 {
		reg = <0x1>;
		timer = <1>;
	};
};

/*
 * Expose the two PWMs (named, so each driver picks the right one) and the A4988
 * direction/enable lines through the standard zephyr,user node. EN is active-low
 * on the A4988, so GPIO_ACTIVE_LOW lets the code treat logical 1 as "driver
 * enabled". Add an external pull-up on EN so the driver stays disabled during
 * boot, before motor_init drives the pin.
 */
/ {
	zephyr,user {
		pwms = <&ledc0 0 PWM_MSEC(1) PWM_POLARITY_NORMAL>,
		       <&ledc0 1 PWM_HZ(440) PWM_POLARITY_NORMAL>;
		pwm-names = "step", "speaker";
		dir-gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
		en-gpios = <&gpio0 19 GPIO_ACTIVE_LOW>;
	};
};
